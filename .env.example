AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_SIZE=1K
GEMINI_TIMEOUT_MS=120000
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_BASE_DELAY_MS=1500
IMAGE_IDENTITY_MIN_CONFIDENCE=0.85
ALLOWED_ORIGINS=http://syntext.ch,https://syntext.ch,http://www.syntext.ch,https://www.syntext.ch,http://localhost:3000
AI_RATE_LIMIT=20
MAX_UPLOAD_MB=10
PORT=3000

# Stripe Checkout
# Prefer a Stripe restricted key (rk_...) with the minimum required Checkout
# Session permissions, or a standard secret key (sk_...) if needed.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_API_VERSION=2026-05-27.dahlia
VITAGEN_BASE_URL=https://syntext.ch/bewerbungs-generator
VITAGEN_CURRENCY=chf
VITAGEN_PRICE_CENTS=990
VITAGEN_PRODUCT_NAME=VitaGen PDF Download
STRIPE_INVOICE_CREATION=true
# Temporary test/staging only: creates 0 CHF Checkout sessions for repeated PDF flow testing.
VITAGEN_FREE_CHECKOUT=false
PAYMENT_RATE_LIMIT=60
JSON_BODY_LIMIT=8mb
